# Example environment variables only — replace placeholders; never commit real secrets.
#
# EasyDeploy public REST API (required for customers: API key only)
EDA_API_KEY=eda_live_YOUR_KEY
#
# Optional: internal/staging only — override API host (default is production EasyDeploy)
# EDA_API_BASE=https://xxxx.execute-api.us-east-1.amazonaws.com/v1

# Optional: dashboard links returned on resources (default https://easydeploy.ai)
# EDA_UI_BASE_URL=https://easydeploy.ai

# Optional: HTTP mode only — require Authorization: Bearer <token> for /mcp (not /healthz)
# MCP_SERVICE_TOKEN=

# Optional: EDA report polling (get_model_report)
# EDA_REPORT_MAX_WAIT_SECONDS=300
# EDA_REPORT_POLL_INTERVAL_SECONDS=10

# HTTP server bind (easydeploy-ai-mcp-http / Docker)
# HOST=0.0.0.0
# PORT=8080
