# Example environment variables only — replace placeholders; never commit real secrets.
#
# Local Docker: COPY this file to `.env` (same directory). The run script only reads `.env`,
# not this file — editing `.env.example` alone does nothing until you `cp .env.example .env`.
# Do not put inline `# comments` on KEY=value lines; Docker --env-file can mangle values.
#
#   cp .env.example .env
#   # edit .env, then:
#   ./scripts/run_mcp_docker_local.sh
#
# EasyDeploy public REST API — required for stdio and legacy HTTP (no OAuth).
# Omit when running HTTP with EDA_OAUTH_ENABLED=1 (outbound auth is per-request only).
EDA_API_KEY=eda_live_YOUR_KEY
#
# REST API host the MCP server calls (tools → httpx). Default in code is production
# https://api.easydeploy.ai — Docker often needs an explicit URL (sandbox execute-api, etc.).
# Omit only if the container can resolve and use production. Match the API your bearer targets.
EDA_API_BASE=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/prod

# Optional: dashboard links returned on resources (default https://easydeploy.ai)
# EDA_UI_BASE_URL=https://easydeploy.ai

# Optional: HTTP mode only — require Authorization: Bearer <token> for /mcp (not /healthz)
# Mutually exclusive with EDA_OAUTH_ENABLED.
# MCP_SERVICE_TOKEN=

# Optional: OAuth resource server (HTTP multi-tenant). Image already includes pyjwt[oauth].
# EDA_COGNITO_CLIENT_ID = Amplify output McpClaudeOauthUserPoolClientId (not the web SPA client).
EDA_OAUTH_ENABLED=1
EDA_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
EDA_COGNITO_CLIENT_ID=your-cognito-client-id
EDA_COGNITO_REGION=us-east-1

# Optional: EDA report polling (get_model_report)
# EDA_REPORT_MAX_WAIT_SECONDS=300
# EDA_REPORT_POLL_INTERVAL_SECONDS=10

# HTTP server bind (easydeploy-ai-mcp-http / Docker)
# HOST=0.0.0.0
# PORT=8080

# Behind AWS ALB / reverse proxy: trust X-Forwarded-Proto so RFC 9728 "resource" is https://…/mcp
# EDA_TRUST_FORWARDED_HEADERS=1

# Optional: public MCP origin for OAuth discovery (authorization_servers + proxy AS metadata issuer).
# Default: request Host + scheme. Set when the reverse proxy does not forward Host/Proto correctly
# so brokers resolve https://your-mcp-host/.well-known/oauth-authorization-server correctly.
# EDA_MCP_OAUTH_ISSUER=https://mcp.sandbox.easydeploy.ai

# Optional: comma-separated extra origins for CORS (Claude web origins are always allowed)
# EDA_CORS_EXTRA_ORIGINS=https://example.com
